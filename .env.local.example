# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Your Anthropic API key — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Your Stripe payment link URL — from the Stripe dashboard (Payment Links)
# Must be a complete URL, e.g. https://buy.stripe.com/test_xxxxx
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_replace_me
